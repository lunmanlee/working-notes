# Files that must NOT be served as part of the published site.
#
# Critical: node_modules is created during the build by `npx wrangler` and
# contains a ~119 MiB binary (workerd) that exceeds Cloudflare's 25 MiB
# per-asset limit. Excluding it is what makes the deploy succeed.
node_modules

# Repo / tooling plumbing — not part of the notes garden.
.git
.github
.gitignore
.assetsignore
wrangler.jsonc
package.json
build.js
scripts
README.md
_bmad
_bmad-output
.claude
